{
  "name": "monkcode-dev",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "sharp"
    ]
  },
  "scripts": {
    "dev": "astro dev --port 4321",
    "build": "astro build",
    "preview": "astro preview",
    "astro:check": "astro check",
    "types:check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "vitest run --exclude test/build.spec.ts",
    "test:watch": "vitest",
    "test:build": "vitest run test/build.spec.ts",
    "check": "pnpm types:check && pnpm astro:check && pnpm lint && pnpm test",
    "og:generate": "node scripts/generate-og.mjs",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.4.1",
    "@astrojs/vue": "^5.1.0",
    "astro": "^5.10.2",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@biomejs/biome": "^2.0.6",
    "@fontsource/inter": "^5.2.5",
    "@fontsource/jetbrains-mono": "^5.2.5",
    "@fontsource/montserrat": "^5.2.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.6",
    "happy-dom": "^18.0.1",
    "sharp": "^0.34.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.12.4"
}
