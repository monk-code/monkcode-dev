---
import Logo from '@/components/Logo.astro'
import { site } from '@/data/site'
---

<footer class="border-t border-(--ink-muted)/20 py-10">
  <div
    class="mx-auto flex max-w-6xl flex-col items-center gap-3 px-6 text-sm text-(--ink-muted)"
  >
    <span class="text-(--ink)"><Logo class="h-6 w-auto" /></span>
    <p class="font-mono">{site.tagline}</p>
    <p>© 2026 {site.name} · {site.owner}</p>
  </div>
</footer>
