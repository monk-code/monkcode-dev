---
import type { PageCopy } from '@/data/types'

type Props = { copy: PageCopy['method'] }
const { copy } = Astro.props
---

<section id="method" class="mx-auto max-w-6xl scroll-mt-20 px-6 py-20 md:py-24">
  <h2 class="beat text-3xl font-bold md:text-4xl">{copy.heading}</h2>
  <p class="mt-5 max-w-prose text-lg text-(--ink-muted)">{copy.intro}</p>
  <ol class="reveal mt-12 grid gap-6 md:grid-cols-2">
    {
      copy.items.map((item, i) => (
        <li class:list={['card p-7', i % 2 === 1 && 'md:translate-y-6']}>
          <span class="font-mono text-2xl font-bold text-(--accent-ink)">
            {String(i + 1).padStart(2, '0')}
          </span>
          <h3 class="mt-3 text-xl font-semibold">{item.title}</h3>
          <p class="mt-3 leading-relaxed text-(--ink-muted)">{item.body}</p>
        </li>
      ))
    }
  </ol>
</section>
