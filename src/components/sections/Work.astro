---
import { Image } from 'astro:assets'
import type { PageCopy } from '@/data/types'

type Props = { copy: PageCopy['work'] }
const { copy } = Astro.props

const images = import.meta.glob<{ default: ImageMetadata }>('@/assets/images/*_800_450.webp', {
  eager: true,
})
const imageFor = (key: string) => Object.entries(images).find(([p]) => p.includes(key))?.[1].default
---

<section id="work" class="mx-auto max-w-6xl scroll-mt-20 px-6 py-20 md:py-24">
  <h2 class="beat text-3xl font-bold md:text-4xl">{copy.heading}</h2>
  <div class="reveal mt-12 grid gap-6 md:grid-cols-2">
    {
      copy.items.map((item, i) => {
        const img = imageFor(item.image)
        return (
          <article class:list={['card overflow-hidden', i % 2 === 1 && 'md:translate-y-8']}>
            {img && (
              <Image
                src={img}
                alt={item.name}
                class="aspect-video w-full object-cover"
                widths={[400, 800]}
                sizes="(min-width: 768px) 50vw, 100vw"
              />
            )}
            <div class="p-7">
              <p class="font-mono text-xs uppercase tracking-widest text-(--accent)">{item.tag}</p>
              <h3 class="mt-2 text-xl font-semibold">
                <a href={item.url} rel="noopener" target="_blank" class="hover:text-(--accent)">
                  {item.name}
                </a>
              </h3>
              <p class="mt-3 leading-relaxed text-(--ink-muted)">{item.description}</p>
            </div>
          </article>
        )
      })
    }
  </div>
  <p class="mt-10 font-mono text-sm text-(--ink-muted) md:mt-16">{copy.footnote}</p>
</section>
