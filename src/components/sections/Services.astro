---
import type { PageCopy } from '@/data/types'

type Props = { copy: PageCopy['services'] }
const { copy } = Astro.props
---

<section id="services" class="mx-auto max-w-6xl scroll-mt-20 px-6 py-20 md:py-24">
  <h2 class="beat text-3xl font-bold md:text-4xl">{copy.heading}</h2>
  <div class="reveal mt-12 grid gap-6 md:grid-cols-3">
    {
      copy.items.map((item, i) => (
        <article class:list={['card p-7', i === 1 && 'md:translate-y-6']}>
          <h3 class="text-xl font-semibold">{item.title}</h3>
          <p class="mt-3 leading-relaxed text-(--ink-muted)">{item.body}</p>
        </article>
      ))
    }
  </div>
</section>
