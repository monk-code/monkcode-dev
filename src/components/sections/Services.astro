---
import type { PageCopy } from '@/data/types'

type Props = { copy: PageCopy['services'] }
const { copy } = Astro.props
---

<section id="services" class="mx-auto max-w-6xl scroll-mt-20 px-6 py-20">
  <h2 class="text-3xl font-bold md:text-4xl">{copy.heading}</h2>
  <div class="mt-10 grid gap-6 md:grid-cols-3">
    {
      copy.items.map((item) => (
        <article class="rounded-xl border border-(--ink-muted)/25 p-6">
          <h3 class="text-xl font-semibold">{item.title}</h3>
          <p class="mt-3 text-(--ink-muted)">{item.body}</p>
        </article>
      ))
    }
  </div>
</section>
