---
import { site } from '@/data/site'
import type { PageCopy } from '@/data/types'

type Props = { copy: PageCopy['contact'] }
const { copy } = Astro.props
---

<section id="contact" class="mx-auto max-w-6xl scroll-mt-20 px-6 py-20 md:py-28">
  <h2 class="beat text-3xl font-bold md:text-4xl">{copy.heading}</h2>
  <p class="mt-6 max-w-prose text-lg leading-relaxed text-(--ink-muted)">{copy.body}</p>
  <div class="mt-9 flex flex-wrap items-center gap-5">
    <a href={`mailto:${site.email}`} class="btn-primary">{site.email}</a>
    <a
      href={site.linkedin}
      rel="noopener"
      target="_blank"
      class="underline decoration-(--accent-ink) decoration-2 underline-offset-4 transition hover:text-(--accent-ink)"
    >
      LinkedIn
    </a>
    <a
      href={site.github}
      rel="noopener"
      target="_blank"
      class="underline decoration-(--accent-ink) decoration-2 underline-offset-4 transition hover:text-(--accent-ink)"
    >
      GitHub
    </a>
  </div>
  <p class="mt-8 font-mono text-sm text-(--ink-muted)">{copy.location}</p>
</section>
