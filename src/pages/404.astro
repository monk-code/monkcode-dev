---
import Logo from '@/components/Logo.astro'
import { getCopy } from '@/data'
import BaseLayout from '@/layouts/BaseLayout.astro'

const copy = getCopy('en')
---

<BaseLayout title={`404 — ${copy.meta.title}`} description={copy.meta.description} locale="en" path="/404">
  <main class="flex min-h-screen flex-col items-center justify-center gap-6 px-6 text-center">
    <span class="text-(--ink)"><Logo class="h-10 w-auto" /></span>
    <p class="font-mono text-6xl font-bold text-(--accent)">404</p>
    <h1 class="text-3xl font-bold">{copy.notFound.title}</h1>
    <p class="max-w-prose text-(--ink-muted)">{copy.notFound.body}</p>
    <a
      href="/"
      class="rounded-md bg-(--accent) px-6 py-3 font-display font-semibold text-(--color-code-black)"
    >
      {copy.notFound.cta}
    </a>
  </main>
</BaseLayout>
